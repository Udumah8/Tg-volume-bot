# Solana Volume Bot Configuration
# Instructions: Rename this file to .env and fill in your details

# [REQUIRED] Your Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_bot_token_here

# [RECOMMENDED] Your Telegram Chat ID. 
# Retrieve this by sending a message to your bot after starting it, or use @userinfobot
# If this is set, ONLY you can control the bot commands.
ADMIN_CHAT_ID=

# [REQUIRED] Your Phantom/Solana Wallet Private Key
# Supports both Base58 string (e.g. 4msR...WJX) or JSON array [1,2,3...]
PRIVKEY=your_private_key_here

# [OPTIONAL] Custom Solana RPC URLs (Comma-separated for failover)
# Default: https://api.mainnet-beta.solana.com
RPC_URL=https://api.mainnet-beta.solana.com
# RPC_URLS=https://rpc1.com,https://rpc2.com

# [OPTIONAL] Jito Block Engine URL (if needed for custom clusters)
# JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

